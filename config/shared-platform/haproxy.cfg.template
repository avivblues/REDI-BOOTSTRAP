global
  log stdout format raw local0
  maxconn 4096

defaults
  log global
  mode tcp
  timeout connect 5s
  timeout client  1m
  timeout server  1m

listen postgres
  bind 0.0.0.0:5432
  mode tcp
  option tcpka
  option httpchk GET /primary
  http-check expect status 200
  default-server inter 3s fall 3 rise 2
  server mjk ${MJK_MESH_IP}:${POSTGRES_MJK_PORT} check port 8008
  server jkt ${JKT_MESH_IP}:${POSTGRES_JKT_PORT} check port 8008
