# Ignore operator-populated secret values.
# Schema stub files (servers.yaml, ssh.yaml, api-keys.yaml, certificates.yaml)
# are committed empty. Once populated with real values, those files must
# never be pushed — verify with: git status secrets/

# Block any additional secret files operators create locally
*.local.yaml
*.env
*.key
*.pem
*.crt
*.p12
*.pfx
acme.json
*.bak
*~
