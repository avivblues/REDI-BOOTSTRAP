# ============================================================
# REDI DEVELOPMENT AGENT SCOPE CONTROL
# ============================================================

# Historical architecture
docs/archive/**

# Historical implementation reports
reports/**
docs/reports/**

# Runtime infrastructure data
data/**
backup/**
backups/**
logs/**

# Generated artifacts
generated/**

# ============================================================
# IMPORTANT
#
# CURSOR SHOULD PRIMARILY READ:
#
# README.md
# compose/
# config/
# scripts/
#
# For GeoDNS task specifically:
#
# config/powerdns/
# compose/powerdns/
# scripts related to PowerDNS / DNS / GeoDNS
#
# Cursor MUST inspect other active files only when required
# by the current task.
# ============================================================