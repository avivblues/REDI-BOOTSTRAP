# =============================================================================
# REDI Shared Platform — Environment (all nodes)
# =============================================================================

# Mesh IPs (Tailscale)
MJK_MESH_IP=100.81.86.37
JKT_MESH_IP=100.79.82.92
SBY_MESH_IP=100.67.138.25
NODE_MESH_IP=CHANGE_ME

# etcd cluster
ETCD_CLUSTER_TOKEN=redi-etcd-cluster
ETCD_INITIAL_CLUSTER=mjk=http://100.81.86.37:2380,jkt=http://100.79.82.92:2380,sby=http://100.67.138.25:2380
ETCD_NODE_NAME=CHANGE_ME

# PostgreSQL (Spilo/Patroni)
POSTGRES_SCOPE=redi-postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME
POSTGRES_REPLICATION_PASSWORD=CHANGE_ME
POSTGRES_SUPERUSER=postgres

# Redis
REDIS_PASSWORD=CHANGE_ME
REDIS_MASTER_HOST=100.81.86.37
REDIS_MASTER_PORT=6379

# MinIO
MINIO_ROOT_USER=rediadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_CLUSTER_ENDPOINTS=http://100.81.86.37:9001/data,http://100.81.86.37:9002/data,http://100.79.82.92:9001/data,http://100.67.138.25:9001/data

# Paths
SHARED_DATA_PATH=/opt/redi/data/shared-platform
SHARED_LOG_PATH=/opt/redi/logs/shared-platform
SHARED_CONFIG_PATH=/opt/redi/config/shared-platform

# Images
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.16
SPILO_IMAGE=registry.opensource.zalan.do/acid/spilo-17:3.3-p2
REDIS_IMAGE=redis:7.4-alpine
HAPROXY_IMAGE=haproxy:2.9-alpine
MINIO_IMAGE=minio/minio:RELEASE.2024-12-18T13-15-44Z
