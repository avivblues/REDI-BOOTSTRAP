# =============================================================================
# REDI LAB — PowerDNS Stack Environment
# Copy to .env and configure per server role (primary | replica)
# =============================================================================

# Node role: primary (redi-jkt-01) or replica (redi-sby-01)
PDNS_NODE_ROLE=primary

# Server identity
PDNS_HOSTNAME=redi-jkt-01
PDNS_TAILSCALE_IP=100.64.0.1

# Primary MariaDB host (Tailscale IP of redi-jkt-01)
MARIADB_PRIMARY_HOST=100.64.0.1
MARIADB_PORT=3306

# Database credentials
MARIADB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MARIADB_REPLICATION_USER=repl_user
MARIADB_REPLICATION_PASSWORD=CHANGE_ME_REPLICATION_PASSWORD
MARIADB_PDNS_USER=pdns
MARIADB_PDNS_PASSWORD=CHANGE_ME_PDNS_DB_PASSWORD
MARIADB_DATABASE=powerdns

# PowerDNS
PDNS_API_KEY=CHANGE_ME_PDNS_API_KEY_MIN_32_CHARS
PDNS_WEBSERVER_ADDRESS=0.0.0.0
PDNS_WEBSERVER_PORT=8081
PDNS_WEBSERVER_ALLOW_FROM=100.64.0.0/10,127.0.0.1,172.28.0.0/24

# DNS zone defaults
REDI_DOMAIN=redi.lab
PDNS_SOA_RNAME=hostmaster.redi.lab
PDNS_SOA_REFRESH=3600
PDNS_SOA_RETRY=600
PDNS_SOA_EXPIRE=604800
PDNS_SOA_MINIMUM=3600

# Image versions (pin for reproducibility)
MARIADB_IMAGE=mariadb:10.11
PDNS_IMAGE=powerdns/pdns-auth-48:4.8.4

# Paths (relative to compose directory)
PDNS_CONFIG_PATH=../../config/powerdns
PDNS_DATA_PATH=../../data/powerdns
PDNS_LOG_PATH=../../logs/powerdns
