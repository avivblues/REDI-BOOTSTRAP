# =============================================================================
# REDI LAB — Portainer Environment
# Management server only: redi-mgmt-01
# =============================================================================

PORTAINER_HOSTNAME=redi-mjk-01
PORTAINER_TAILSCALE_IP=100.81.86.37
PORTAINER_DOMAIN=portainer.letsredi.com

# Shared secret for Portainer agents (all nodes must match)
PORTAINER_AGENT_SECRET=CHANGE_ME_AGENT_SECRET_MIN_32_CHARS

# Admin password — bcrypt hash required
# Generate bcrypt hash only (no admin: prefix):
# docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'your-password' | cut -d: -f2 | sed -e 's/\$/\$\$/g'
PORTAINER_ADMIN_PASSWORD=$$2y$$05$$REPLACE_WITH_BCRYPT_HASH

# Image
PORTAINER_IMAGE=portainer/portainer-ce:2.27.3

# Paths
PORTAINER_DATA_PATH=../../data/portainer
PORTAINER_LOG_PATH=../../logs/portainer

# Traefik labels (attached via compose)
TRAEFIK_NETWORK=redi-proxy
