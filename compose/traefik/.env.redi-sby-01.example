# =============================================================================
# REDI LAB — Traefik Environment (redi-sby-01)
# Sprint 3D — GeoDNS edge node SBY
# Copy to .env and fill in secrets before deploying.
# =============================================================================

TRAEFIK_HOSTNAME=redi-sby-01
TRAEFIK_TAILSCALE_IP=100.67.138.25

# Domain
REDI_DOMAIN=redi.lab
REDI_ACME_EMAIL=ops@letsredi.com

# Dashboard — bound to Tailscale IP only (port 8080)
TRAEFIK_DASHBOARD_ENABLED=true
TRAEFIK_DASHBOARD_DOMAIN=traefik-sby.redi.lab
TRAEFIK_DASHBOARD_USER=admin
# Generate: htpasswd -nbB admin 'your-password' | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_PASSWORD_HASH=$$2y$$05$$REPLACE_WITH_BCRYPT_HASH

# PowerDNS API — reach jkt's pdns via Tailscale for DNS-01 ACME challenge
# jkt Tailscale IP: 100.79.82.92
PDNS_API_URL=http://100.79.82.92:8081
PDNS_API_KEY=CHANGE_ME_PDNS_API_KEY_MIN_32_CHARS

# Image (pin same version as jkt)
TRAEFIK_IMAGE=traefik:v3.6.1

# Paths — override to use sby-specific static config
TRAEFIK_CONFIG_PATH=../../config/traefik
TRAEFIK_STATIC_CONFIG=traefik.sby.yml
TRAEFIK_DATA_PATH=../../data/traefik-sby
TRAEFIK_LOG_PATH=../../logs/traefik-sby

# Logging
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_ACCESS_LOG=true
