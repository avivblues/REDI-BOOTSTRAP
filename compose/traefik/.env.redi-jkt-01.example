# =============================================================================
# REDI LAB — Traefik Environment (redi-jkt-01 primary edge)
# Copy to .env before deploying. PDNS_API_KEY can be synced from compose/powerdns/.env
# =============================================================================

TRAEFIK_HOSTNAME=redi-jkt-01
TRAEFIK_TAILSCALE_IP=100.79.82.92
TRAEFIK_DASHBOARD_PORT=8888

REDI_DOMAIN=letsredi.com
REDI_ACME_EMAIL=ops@letsredi.com

TRAEFIK_DASHBOARD_ENABLED=true
TRAEFIK_DASHBOARD_DOMAIN=traefik-jkt.redi.lab
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=$$2y$$05$$REPLACE_WITH_BCRYPT_HASH

# PowerDNS API — local Docker DNS network (deploy-traefik.sh may override to redi-pdns-auth:8081)
PDNS_API_URL=http://100.79.82.92:8081
PDNS_API_KEY=CHANGE_ME_PDNS_API_KEY_MIN_32_CHARS

TRAEFIK_IMAGE=traefik:v3.6.1
DOCKER_SOCKET_PROXY_IMAGE=tecnativa/docker-socket-proxy:latest

TRAEFIK_CONFIG_PATH=../../config/traefik
TRAEFIK_DATA_PATH=../../data/traefik
TRAEFIK_LOG_PATH=../../logs/traefik

TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_ACCESS_LOG=true
